rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Reusable Auth Functions ---
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'sumanthbolla97@gmail.com';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // --- 1. Users Collection ---
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Address Subcollection Validation
      match /addresses/{addressId} {
        allow read, delete: if isOwner(userId) || isAdmin();
        
        // Enforce strict schema and data types on address creation/updates
        allow create, update: if (isOwner(userId) || isAdmin()) &&
          request.resource.data.fullName is string && request.resource.data.fullName.size() > 0 &&
          request.resource.data.phone is string && request.resource.data.phone.size() > 0 &&
          request.resource.data.addressLine1 is string && request.resource.data.addressLine1.size() > 0 &&
          request.resource.data.city is string && request.resource.data.city.size() > 0 &&
          request.resource.data.state is string && request.resource.data.state.size() > 0 &&
          request.resource.data.pincode is string && request.resource.data.pincode.size() >= 5;
      }
    }

    // --- 2. Orders Collection ---
    match /orders/{orderId} {
      // Users can only read their own orders. Admin can read all.
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      
      // Order Validation: Enforce total > 0, items array is not empty, and user can't spoof another UID.
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid &&
        request.resource.data.total is number && request.resource.data.total >= 0 &&
        request.resource.data.items is list && request.resource.data.items.size() > 0;
        
      // Users cannot edit or delete an order once placed. Only Admin can update status.
      allow update, delete: if isAdmin();
    }

    // --- 3. Products Catalog ---
    match /products/{productId} {
      allow read: if true; // Public catalog
      allow write: if isAdmin(); // Only admins can add/update/delete products and adjust stock
    }

    // --- 4. Carts Collection ---
    match /carts/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
  }
}